{
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(date:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(echo:*)",
      "Bash(mkdir:*)",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(sudo rm:*)",
      "Bash(rm -rf /:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh .github/hooks/check-version-format.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
